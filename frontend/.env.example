# Optional — Vite dev. On Vercel, `VERCEL=1` at build uses same-origin /api (see vite.config + vercel.json).

# Local dev: where Vite proxies /api (default http://127.0.0.1:8000)
# VITE_BACKEND_URL=http://127.0.0.1:8000

# Force relative /api in a production build (e.g. static host with /api proxy)
# VITE_RELATIVE_API=1

# VITE_DEV_PORT=3000
