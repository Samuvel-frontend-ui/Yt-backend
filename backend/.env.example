# Set in Render → Environment (never commit real secrets).

# CORS: allowed frontend origins are hardcoded in main.py (ALLOWED_CORS_ORIGINS).

# --- YouTube (optional) ---
# Only if many videos return 503 / "sign in" / bot errors — paste Cookie from a logged-in browser (private use).
# YOUTUBE_COOKIE=

# --- Rare ---
# FFMPEG_LOCATION=   # only if ffmpeg not on PATH (Docker image already has /usr/bin)
