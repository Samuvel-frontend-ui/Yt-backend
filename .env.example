# Set on the host (Render dashboard, shell, systemd) — do not commit real values.

# Required for browser clients: your Vercel site origin(s), comma-separated, no trailing slashes
# FRONTEND_ORIGIN=https://your-app.vercel.app

# Optional: bot-gated YouTube (private use only)
# YOUTUBE_COOKIE=

# Optional: if ffmpeg/ffprobe are not on PATH (Dockerfile already includes them in /usr/bin)
# FFMPEG_LOCATION=
